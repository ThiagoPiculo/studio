
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user is part of a specific family
    function isFamilyMember(familyId, userId) {
      return exists(/databases/$(database)/documents/familyMemberships/$(userId)_$(familyId));
    }

    // Helper function to check a user's role in a family
    function getFamilyRole(familyId, userId) {
      return get(/databases/$(database)/documents/familyMemberships/$(userId)_$(familyId)).data.role;
    }

    // Users can only read their own profile, but can be created by anyone (during sign up)
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
    
    // Children can be read by their owner or family members
    // They can only be created/updated/deleted by their owner
    match /children/{childId} {
      allow read: if request.auth != null && 
                  (resource.data.ownerId == request.auth.uid || 
                  (resource.data.familyId != null && isFamilyMember(resource.data.familyId, request.auth.uid)));
      allow create, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Families can be read by their members.
    // Write access is generally managed by specific roles (checked in backend functions).
    match /families/{familyId} {
      allow read: if request.auth != null && isFamilyMember(familyId, request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // Family memberships can be read by the user themselves or by other members of the same family.
    // Creations/deletions are handled by backend logic (invites/leaving).
    match /familyMemberships/{membershipId} {
        allow read: if request.auth != null && 
                    (resource.data.userId == request.auth.uid || isFamilyMember(resource.data.familyId, request.auth.uid));
        allow create: if request.auth != null; // User joining/being added
        allow delete: if request.auth != null && 
                      (resource.data.userId == request.auth.uid || // User leaving
                       getFamilyRole(resource.data.familyId, request.auth.uid) == 'Owner'); // Owner removing member
        allow update: if request.auth != null && getFamilyRole(resource.data.familyId, request.auth.uid) == 'Owner';
    }
    
    // Invitations can be read by the invitee or the family owner.
    match /familyInvitations/{invitationId} {
        allow read, update: if request.auth != null && 
                        (resource.data.inviteeId == request.auth.uid || 
                         isFamilyMember(resource.data.familyId, request.auth.uid));
        allow create, delete: if request.auth != null;
    }

    // Templates (Mission/Reward) can be read by owner or family members.
    // Write access is for the owner.
    match /{templateCollection}/{templateId} where templateCollection in ['missionTemplates', 'rewardTemplates'] {
       allow read: if request.auth != null && 
                  (resource.data.ownerId == request.auth.uid || 
                  (resource.data.familyId != null && isFamilyMember(resource.data.familyId, request.auth.uid)));
       allow create, update, delete: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }
    
    // Instances (Mission/Reward) can be read by owner or family members.
    // Writes are more complex and often handled by backend logic, but this allows basic updates.
    match /{instanceCollection}/{instanceId} where instanceCollection in ['missionInstances', 'childRewardInstances'] {
       allow read, create, update, delete: if request.auth != null && 
                  (resource.data.ownerId == request.auth.uid || 
                  (resource.data.familyId != null && isFamilyMember(resource.data.familyId, request.auth.uid)));
    }
    
    match /schoolSchedules/{scheduleId} {
       allow read, create, update, delete: if request.auth != null && 
                  (resource.data.ownerId == request.auth.uid || 
                  (resource.data.familyId != null && isFamilyMember(resource.data.familyId, request.auth.uid)));
    }
    
    // Notifications are private to the user.
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }
    
    // Votes are public to read the count, but writing is controlled.
    match /feature_votes/{featureId} {
        allow read: if true;
        allow write: if false; // All writes must go through transaction in firestore.ts
    }
    
    match /feature_votes/{featureId}/voters/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // All writes must go through transaction in firestore.ts
    }
  }
}
