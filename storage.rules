rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Regra geral: por padrão, ninguém pode ler ou escrever.
    match /{allPaths=**} {
      allow read, write: if false;
    }
    
    // Permite que qualquer usuário autenticado escreva na pasta de avatares.
    // A segurança de qual usuário pode escrever em qual subpasta é controlada
    // pela lógica da aplicação (Server Action ou client-side code).
    match /avatars/{userId}/{childId}/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
