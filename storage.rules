rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Regras de segurança para avatares dos Mini-Herois
    // Permite que um usuário autenticado escreva na sua própria pasta de avatares.
    // A leitura é pública para que qualquer pessoa possa ver os avatares.
    match /avatars/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regras de segurança para avatares dos Usuários (pais/responsáveis)
    // Mesma lógica: usuário autenticado pode escrever no seu próprio diretório.
    match /user_avatars/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
