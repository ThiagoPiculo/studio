
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer usuário autenticado leia e escreva na pasta de avatares.
    // A segurança de "quem pode escrever em qual subpasta" é garantida pela sua
    // Server Action, que verifica se o usuário logado corresponde ao childId.
    match /avatars/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
  }
}
