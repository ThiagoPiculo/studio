rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Regras de Segurança para Avatares de Usuários (Responsáveis)
    match /user_avatars/{userId}/{allPaths=**} {
      // Qualquer um pode ler avatares
      allow read;
      // Apenas o usuário autenticado pode escrever em seu próprio diretório
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regras de Segurança para Avatares de Crianças (Mini Herois)
    match /avatars/{ownerId}/{childId}/{allPaths=**} {
      // Qualquer um pode ler avatares
      allow read;
      // Apenas o "dono" do perfil da criança pode escrever
      allow write: if request.auth != null && request.auth.uid == ownerId;
    }
  }
}
