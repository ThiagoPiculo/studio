rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer pessoa leia os avatares (eles são públicos por natureza)
    // e permite a escrita sem verificar a autenticação, pois a segurança
    // será controlada pela lógica da aplicação (Server Action).
    match /avatars/{userId}/{allPaths=**} {
      allow read;
      allow write;
    }
  }
}
